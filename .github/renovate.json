{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>lexfrei/renovate-config",
    ":enableVulnerabilityAlertsWithLabel(security)",
    "schedule:weekly"
  ],
  "labels": ["dependencies"],
  "ignorePaths": [
    "**/node_modules/**",
    "**/vendor/**"
  ],
  "rangeStrategy": "pin",
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
  "dockerfile": {
    "fileMatch": ["(^|/)Containerfile$", "(^|/)Dockerfile$"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"],
    "schedule": ["at any time"],
    "automerge": false
  },
  "packageRules": [
    {
      "description": "Group all Go module updates",
      "matchManagers": ["gomod"],
      "groupName": "go modules",
      "groupSlug": "go-modules"
    },
    {
      "description": "Group all GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "groupSlug": "github-actions"
    },
    {
      "description": "Automerge patch updates for Go modules",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Automerge all GitHub Actions updates including major",
      "matchManagers": ["github-actions"],
      "automerge": true
    },
    {
      "description": "Group and automerge all CI tooling — golangci-lint binary, helm-unittest plugin, gateway-api CRDs. Anything that only runs in CI and never reaches production.",
      "matchPackageNames": [
        "golangci/golangci-lint",
        "helm-unittest/helm-unittest",
        "kubernetes-sigs/gateway-api"
      ],
      "groupName": "ci tooling",
      "groupSlug": "ci-tooling",
      "automerge": true,
      "schedule": ["at any time"]
    },
    {
      "description": "Pin and update Go base image in Containerfile (pulled via mirror.gcr.io to dodge Docker Hub rate-limits)",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["mirror.gcr.io/library/golang"],
      "versioning": "docker"
    },
    {
      "description": "Bump the go directive in go.mod (rangeStrategy=bump). Major Go releases (1.x -> 2.x) are not blocked here; if/when one ships it will arrive as a separate PR via :separateMajorReleases.",
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "matchDepTypes": ["golang"],
      "rangeStrategy": "bump"
    },
    {
      "description": "Group e2e harness images (test/e2e/* — not shipped, only used by CI)",
      "matchFileNames": ["test/e2e/**"],
      "groupName": "e2e harness images",
      "groupSlug": "e2e-images",
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "description": "kubectl run --image=<repo>:<tag> in test/e2e/run.sh",
      "customType": "regex",
      "fileMatch": ["test/e2e/run\\.sh"],
      "matchStrings": [
        "--image=(?<depName>[a-zA-Z0-9._/-]+):(?<currentValue>[a-zA-Z0-9._-]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "description": "Plain 'image: <repo>:<tag>' lines in e2e workloads",
      "customType": "regex",
      "fileMatch": ["test/e2e/test-workloads\\.yaml"],
      "matchStrings": [
        "image:\\s+(?<depName>[a-zA-Z0-9._/-]+):(?<currentValue>[a-zA-Z0-9._-]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "description": "golangci-lint-action 'version: vX.Y.Z'",
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/.+\\.ya?ml$"],
      "matchStrings": [
        "golangci/golangci-lint-action@[a-f0-9]+ # v\\d+\\s+with:\\s+version:\\s+(?<currentValue>v[\\d.]+)"
      ],
      "depNameTemplate": "golangci/golangci-lint",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^(?<version>v.+)$"
    },
    {
      "description": "helm-unittest plugin '--version vX.Y.Z' pinned in CI",
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/.+\\.ya?ml$"],
      "matchStrings": [
        "helm-unittest/helm-unittest --version (?<currentValue>v[\\d.]+)"
      ],
      "depNameTemplate": "helm-unittest/helm-unittest",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^(?<version>v.+)$"
    }
  ]
}
